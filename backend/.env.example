# ── Supabase ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Database (local Docker or Supabase connection string) ────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/meeting_app

# ── Speech-to-Text ───────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
DEEPGRAM_API_KEY=

# ── LLM Processing ──────────────────────────────────────────────────
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ── Twenty CRM (self-hosted on VPS) ─────────────────────────────────
TWENTY_API_URL=https://crm.yourdomain.com
TWENTY_API_KEY=your-twenty-api-key

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8081","http://localhost:19006"]
