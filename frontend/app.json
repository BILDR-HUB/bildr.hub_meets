{
  "expo": {
    "name": "bildr hub meets",
    "slug": "bildr-hub-meets",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "meeting-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
